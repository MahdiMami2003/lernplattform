    "section4": {
      "title": "4. Storage of your data (Supabase)",
      "text1": "User accounts and login data are processed and stored using ",
      "supabase": "Supabase",
      "text2": ". Supabase is a cloud-based database service used for user management and authentication.",
      "text3": "Data is stored on servers outside our school. Access by teachers and project administrators is possible, but only for learning and administrative purposes."
    },
    "section5": {
      "title": "5. Data sharing",
      "text": "No data is shared with third parties outside of this project."
    },
    "section6": {
      "title": "6. Your rights",
      "text": "You have the right to:",
      "list": {
        "access": "request information about your stored data,",
        "correct_delete": "request correction or deletion,",
        "object": "object to the use of your data."
      }
    },
    "section7": {
      "title": "7. Contact for privacy questions",
      "text": "If you have questions or concerns, you can contact us via the email address provided in the imprint."
    }
